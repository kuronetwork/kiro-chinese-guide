---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Playground from '../../../components/Playground.astro';
import { t } from '../../../i18n/ui';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const locale = 'en';
---
<BaseLayout
  title={`${t(locale, 'game.title')} · Kiro CLI Guide`}
  description={t(locale, 'game.subtitle')}
  locale={locale}
  switchHref={`${base}/playground/`}
  alternates={[
    { hreflang: 'zh-Hant', href: `${base}/playground/` },
    { hreflang: 'en', href: `${base}/en/playground/` },
    { hreflang: 'x-default', href: `${base}/playground/` },
  ]}
>
  <Playground locale={locale} />
</BaseLayout>
