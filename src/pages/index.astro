---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const docs = (await getCollection('docs')).sort((a, b) => a.data.order - b.data.order);
const first = docs[0];

const groups: { label: string; items: typeof docs }[] = [];
for (const doc of docs) {
  let g = groups.find((x) => x.label === doc.data.section);
  if (!g) { g = { label: doc.data.section, items: [] }; groups.push(g); }
  g.items.push(doc);
}
---
<BaseLayout title="Kiro CLI 繁中教學 — 從零到自動化">
  <Sidebar current="" />
  <main class="content">
    <div class="home-inner">
      <section class="hero">
        <div class="term">
          <div class="term-bar"><span class="r"></span><span class="y"></span><span class="g"></span>
            <span class="term-name">zsh — kiro-cli</span>
          </div>
          <pre class="term-body"><span class="c-muted"># 在任何專案資料夾,叫出 Terminal 裡的 AI agent</span>
<span class="c-prompt">❯</span> kiro-cli chat
<span class="c-accent">Kiro CLI 2.6.1</span> — 已就緒。輸入你的任務…
<span class="c-prompt">❯</span> 幫我把這個專案的測試補齊並跑過
<span class="c-dim">› 規劃任務 › 讀取程式碼 › 寫測試 › 執行 › 完成 ✓</span>
<span class="cursor">█</span></pre>
        </div>
        <div class="hero-copy">
          <h1>Kiro CLI 繁中教學</h1>
          <p class="lead">
            把 AI agent 帶進你的 Terminal。從第一次對話開始,
            一路帶你走到多專案平行的全自動工作流。
          </p>
          <p class="sub">繁體中文 · 每段都附能直接複製的範例 · 對應 Kiro CLI 2.6.1</p>
          <div class="cta">
            {first && <a class="btn primary" href={`${base}/${first.id}/`}>開始學習 ❯</a>}
            <a class="btn ghost" href="#path">看學習路徑</a>
          </div>
        </div>
      </section>

      <section id="path" class="path">
        <h2 class="path-title"># 學習路徑</h2>
        <div class="path-grid">
          {groups.map((g, i) => (
            <div class="path-card">
              <div class="path-card-head">
                <span class="idx">{String(i + 1).padStart(2, '0')}</span>
                <span class="sec">{g.label}</span>
              </div>
              <ul>
                {g.items.map((item) => (
                  <li><a href={`${base}/${item.id}/`}>{item.data.title}</a></li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>

      <footer class="home-foot">
        <p>非官方社群教學,內容經整理並翻譯為中文,輔助學習使用,請以官方指令為準。與 Amazon / AWS 無關聯。指令行為以你本機的 <code>kiro-cli --help</code> 為準。</p>
      </footer>
    </div>
  </main>
</BaseLayout>

<style>
  .home-inner { max-width: 1000px; margin: 0 auto; }
  .hero { display: grid; grid-template-columns: 1.05fr 1fr; gap: 40px; align-items: center; padding: 24px 0 48px; }
  @media (max-width: 860px) { .hero { grid-template-columns: 1fr; } }

  .term { border: 1px solid var(--border); border-radius: 10px; overflow: hidden; background: #0a0d12; box-shadow: 0 24px 60px rgba(0,0,0,0.45); }
  .term-bar { display: flex; align-items: center; gap: 7px; padding: 9px 13px; background: var(--panel); border-bottom: 1px solid var(--border); }
  .term-bar span:not(.term-name) { width: 12px; height: 12px; border-radius: 50%; }
  .term-bar .r { background: #ff5f57; } .term-bar .y { background: #febc2e; } .term-bar .g { background: #28c840; }
  .term-name { margin-left: 8px; font-family: var(--mono); font-size: 12px; color: var(--faint); }
  .term-body { margin: 0; padding: 18px; font-family: var(--mono); font-size: 13.5px; line-height: 1.85; color: var(--fg); white-space: pre-wrap; }
  .c-muted { color: var(--faint); } .c-prompt { color: var(--amber); } .c-accent { color: var(--accent); } .c-dim { color: var(--muted); }
  .cursor { color: var(--accent); animation: blink 1.1s steps(1) infinite; }
  @keyframes blink { 50% { opacity: 0; } }

  .hero-copy h1 { font-family: var(--mono); font-size: clamp(28px, 4vw, 40px); line-height: 1.2; color: var(--fg-strong); margin: 0 0 16px; }
  .lead { font-size: 17px; line-height: 1.85; margin: 0 0 12px; }
  .sub { color: var(--muted); font-size: 14px; margin: 0 0 22px; }
  .cta { display: flex; gap: 12px; flex-wrap: wrap; }
  .btn { font-family: var(--mono); font-size: 14px; padding: 11px 20px; border-radius: 7px; border: 1px solid var(--border); }
  .btn.primary { background: var(--accent); color: #06140f; border-color: var(--accent); font-weight: 700; }
  .btn.primary:hover { background: #7bf0c5; text-decoration: none; }
  .btn.ghost { color: var(--fg); } .btn.ghost:hover { border-color: var(--accent-dim); color: var(--accent); text-decoration: none; }

  .path-title { font-family: var(--mono); font-size: 22px; color: var(--fg-strong); margin: 8px 0 22px; }
  .path-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 16px; }
  .path-card { border: 1px solid var(--border); border-radius: 10px; background: var(--bg-soft); padding: 16px 18px; transition: border-color .15s; }
  .path-card:hover { border-color: var(--accent-dim); }
  .path-card-head { display: flex; align-items: baseline; gap: 10px; margin-bottom: 10px; padding-bottom: 10px; border-bottom: 1px solid var(--border-soft); }
  .path-card-head .idx { font-family: var(--mono); font-size: 20px; color: var(--accent); font-weight: 700; }
  .path-card-head .sec { font-family: var(--mono); font-size: 14px; color: var(--fg-strong); }
  .path-card ul { list-style: none; margin: 0; padding: 0; }
  .path-card li { margin: 5px 0; }
  .path-card li a { color: var(--muted); font-size: 14.5px; }
  .path-card li a:hover { color: var(--accent); }
  .path-card li::before { content: '› '; color: var(--faint); }

  .home-foot { margin-top: 56px; padding-top: 22px; border-top: 1px solid var(--border); color: var(--faint); font-size: 13px; }
  .home-foot code { font-family: var(--mono); color: var(--muted); }
</style>
