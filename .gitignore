# ──────────────────────────────────────────────
#  相依套件(由 package-lock.json 還原,不進版控)
# ──────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
jspm_packages/

# ──────────────────────────────────────────────
#  建置產物與框架產生的暫存(可重新產生)
# ──────────────────────────────────────────────
dist/
.astro/
.output/
.vercel/
.netlify/
*.tsbuildinfo

# ──────────────────────────────────────────────
#  機敏資訊 — 嚴禁進版控
#  (環境變數、金鑰、憑證、登入權杖等)
# ──────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.cert
*.crt
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
*.keystore
credentials
credentials.json
secrets/
.secrets/
# npm/yarn 認證設定可能含 _authToken,一律排除
.npmrc
.yarnrc
.yarnrc.yml
# 雲端供應商憑證
.aws/
.gcp/
*.gcloud.json

# ──────────────────────────────────────────────
#  Log 與除錯輸出
# ──────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ──────────────────────────────────────────────
#  測試/快取
# ──────────────────────────────────────────────
coverage/
.nyc_output/
.cache/
.eslintcache

# ──────────────────────────────────────────────
#  作業系統產生的檔案
# ──────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ──────────────────────────────────────────────
#  編輯器/IDE 個人設定
# ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-workspace

# ──────────────────────────────────────────────
#  AI 助理 / 開發工具的本機設定(不該進公開 repo)
#  Kiro Spec、steering、本機 agent 設定、其他助理目錄
# ──────────────────────────────────────────────
.kiro/
.cursor/
.windsurf/
.continue/
.aider*
CLAUDE.md
.claude/

